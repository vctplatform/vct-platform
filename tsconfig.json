{
  "compilerOptions": {
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "app/*": [
        "./packages/app/*"
      ],
      "@vct/shared-types": [
        "./packages/shared-types/src/index.ts"
      ],
      "@vct/ui": [
        "./packages/ui/src/index.ts"
      ]
    },
    "baseUrl": ".",
    "jsx": "react-jsx"
  }
}