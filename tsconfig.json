{
  "compilerOptions": {
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "paths": {
      "app/*": [
        "./packages/app/*"
      ],
      "@vct/shared-types": [
        "./packages/shared-types/src/index.ts"
      ],
      "@vct/ui": [
        "./packages/ui/src/index.ts"
      ]
    },
    "baseUrl": ".",
    "jsx": "react-jsx"
  },
  "include": [
    "packages/app/rnw-overrides.d.ts",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "apps/**/*.ts",
    "apps/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules"
  ]
}