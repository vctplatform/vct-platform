# ============================================
# Self-host PostgreSQL 18
# ============================================
VCT_STORAGE_DRIVER=postgres
VCT_POSTGRES_PROVIDER=selfhost
VCT_POSTGRES_URL=postgres://vct:vct@127.0.0.1:5432/vct?sslmode=disable
VCT_DB_AUTO_MIGRATE=true
VCT_CACHE_TTL=30s
VCT_CACHE_MAX_ENTRIES=2000

