VCT_ENV=development
VCT_BACKEND_ADDR=:18080
VCT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://localhost:3101,http://127.0.0.1:3101
VCT_DISABLE_AUTH_FOR_DATA=false
VCT_ALLOW_DEMO_USERS=true
# VCT_BOOTSTRAP_USERS_JSON=[{"username":"ops-admin","password":"change-me","displayName":"Ops Admin","roles":["admin"]}]
VCT_JWT_SECRET=change-me-before-production-vct-2026
VCT_JWT_ISSUER=vct-backend
VCT_ACCESS_TTL=15m
VCT_REFRESH_TTL=168h
VCT_AUDIT_LIMIT=5000
VCT_STORAGE_DRIVER=memory
VCT_POSTGRES_URL=
VCT_POSTGRES_PROVIDER=selfhost
VCT_DB_AUTO_MIGRATE=true
VCT_CACHE_TTL=30s
VCT_CACHE_MAX_ENTRIES=2000
# See backend/.env.providers.example for selfhost/neon/supabase templates
