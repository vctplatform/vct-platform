# ═══════════════════════════════════════════════════════════════
# VCT Platform — Environment Variables Template
# Copy to .env and update values for your environment.
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=vct_platform
POSTGRES_USER=vct_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432
DATABASE_URL=postgres://vct_admin:change_me_in_production@localhost:5432/vct_platform?sslmode=disable

# ── Backend (Go) ─────────────────────────────────────────────
PORT=8080
GO_ENV=development
JWT_SECRET=change_this_to_a_secure_random_string
CORS_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Push Notifications (VAPID) ───────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Upstash Redis (optional, for caching) ─────────────
# Create at: https://console.upstash.com  (select Singapore region)
UPSTASH_REDIS_URL=

# ── Docker ────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080

# ── Resend Email (OTP verification) ───────────────────────────
# Get API key from: https://resend.com/api-keys
VCT_RESEND_API_KEY=
VCT_RESEND_FROM_EMAIL=onboarding@resend.dev
