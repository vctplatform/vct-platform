{
  "name": "solito-blank",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/react": "^18.2.21",
    "eslint": "^8.21.0",
    "turbo": "^2.4.4",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "dev": "npm run dev --workspace next-app",
    "dev:web": "npm run dev --workspace next-app",
    "dev:native": "npm run start --workspace expo-app",
    "build": "npm run build --workspace next-app",
    "lint": "npm run lint --workspace next-app && npx eslint packages/app --ext .ts,.tsx",
    "typecheck": "npx tsc -p tsconfig.json --noEmit",
    "test": "node scripts/run-tests.mjs",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "native": "npm run dev:native",
    "web": "npm run dev:web"
  },
  "packageManager": "yarn@4.7.0",
  "eslintConfig": {
    "extends": "next",
    "settings": {
      "next": {
        "rootDir": "apps/next/"
      }
    },
    "rules": {
      "@next/next/no-html-link-for-pages": "off"
    },
    "root": true
  },
  "prettier": {
    "semi": false,
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true
  },
  "dependencies": {
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "lucide-react-native": "^0.577.0"
  }
}
