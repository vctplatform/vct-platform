{
  "name": "vct-platform",
  "private": true,
  "description": "VCT Platform — Nền tảng Quản trị Võ thuật Toàn diện cho Võ Cổ Truyền Việt Nam",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.1",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "dev": "npm run dev --workspace next-app",
    "dev:web": "npm run dev --workspace next-app",
    "dev:backend": "go -C backend run ./cmd/server",
    "dev:native": "npm run start --workspace expo-app",
    "build": "npm run authz:sync && npm run typecheck && npm run build --workspace next-app",
    "build:web:full": "npm run authz:sync && npm run typecheck && npm run build:full --workspace next-app",
    "build:backend": "go -C backend build -o ./bin/vct-backend ./cmd/server",
    "lint": "npm run lint --workspace next-app && npx eslint \"packages/app/**/*.{ts,tsx}\"",
    "lint:arch": "npx eslint --rule '{\"boundaries/element-types\": \"error\"}' \"packages/**/*.{ts,tsx}\" --no-warn-ignored",
    "lint:boundaries": "node scripts/check-boundaries.mjs",
    "typecheck": "npx tsc -p tsconfig.json --noEmit",
    "authz:sync": "node scripts/generate-authz-contract.mjs",
    "authz:check": "node scripts/generate-authz-contract.mjs --check",
    "test": "node scripts/run-tests.mjs",
    "test:smoke": "node scripts/run-tests.mjs --smoke-only",
    "test:admin": "npx vitest run --configLoader native packages/app/features/admin/__tests__",
    "test:mobile:logic": "npx vitest run --configLoader native --config vitest.mobile.config.mjs",
    "test:ui": "playwright test tests/e2e/appshell.breakpoints.spec.mjs --config=playwright.config.mjs",
    "test:e2e": "playwright test tests/e2e/core-workflow.spec.mjs --config=playwright.config.mjs",
    "smoke:backend:db": "node scripts/run-backend-db-smoke.mjs",
    "quality:backend": "powershell -ExecutionPolicy Bypass -File scripts/run_quality_checks.ps1 -BackendPath ./backend",
    "ci": "npm run authz:check && npm run typecheck && npm run lint && npm run test && npm run build",
    "native": "npm run dev:native",
    "web": "npm run dev:web",
    "backend": "go -C backend run ./cmd/server",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ],
    "*.go": [
      "echo Go files changed — run 'go vet ./...' before push"
    ]
  },
  "prettier": {
    "semi": false,
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true
  },
  "dependencies": {
    "framer-motion": "^12.37.0",
    "lucide-react": "^0.577.0",
    "lucide-react-native": "^0.577.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
