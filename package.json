{
  "name": "vct-platform",
  "private": true,
  "description": "VCT Platform — Nền tảng Quản trị Võ thuật Toàn diện cho Võ Cổ Truyền Việt Nam",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/react": "^18.2.21",
    "eslint": "^8.21.0",
    "turbo": "^2.4.4",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "dev": "npm run dev --workspace next-app",
    "dev:web": "npm run dev --workspace next-app",
    "dev:backend": "go -C backend run ./cmd/server",
    "dev:native": "npm run start --workspace expo-app",
    "build": "npm run authz:check && npm run build --workspace next-app",
    "build:backend": "go -C backend build -o ./bin/vct-backend ./cmd/server",
    "lint": "npm run lint --workspace next-app && npx eslint packages/app --ext .ts,.tsx",
    "typecheck": "npx tsc -p tsconfig.json --noEmit",
    "authz:sync": "node scripts/generate-authz-contract.mjs",
    "authz:check": "node scripts/generate-authz-contract.mjs --check",
    "test": "node scripts/run-tests.mjs",
    "test:ui": "playwright test tests/e2e/appshell.breakpoints.spec.mjs --config=playwright.config.mjs",
    "test:e2e": "playwright test tests/e2e/core-workflow.spec.mjs --config=playwright.config.mjs",
    "smoke:backend:db": "node scripts/run-backend-db-smoke.mjs",
    "quality:backend": "powershell -ExecutionPolicy Bypass -File scripts/run_quality_checks.ps1 -BackendPath ./backend",
    "ci": "npm run authz:check && npm run typecheck && npm run lint && npm run test && npm run build",
    "native": "npm run dev:native",
    "web": "npm run dev:web",
    "backend": "go -C backend run ./cmd/server"
  },
  "packageManager": "yarn@4.7.0",
  "eslintConfig": {
    "extends": "next",
    "settings": {
      "next": {
        "rootDir": "apps/next/"
      }
    },
    "rules": {
      "@next/next/no-html-link-for-pages": "off"
    },
    "root": true
  },
  "prettier": {
    "semi": false,
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true
  },
  "dependencies": {
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "lucide-react-native": "^0.577.0",
    "zod": "^4.3.6"
  }
}
