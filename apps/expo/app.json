{
  "expo": {
    "name": "VCT Platform",
    "slug": "vct-platform",
    "version": "1.0.0",
    "scheme": "vct-platform",
    "orientation": "portrait",
    "platforms": ["ios", "android", "web"],
    "ios": {
      "bundleIdentifier": "com.vctplatform.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.vctplatform.app",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      }
    },
    "newArchEnabled": true,
    "experiments": {
      "reactCanary": true
    }
  }
}
